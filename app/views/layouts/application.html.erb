<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Todo App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body class="bg-gradient-to-br from-gray-100 via-white to-gray-200 dark:from-gray-900 dark:via-gray-800 dark:to-gray-700 min-h-screen antialiased text-gray-800 dark:text-gray-100 transition-colors duration-300 ease-in-out">

    <!-- 🌗 Dark Mode Toggle Button -->
    <button
      onclick="document.documentElement.classList.toggle('dark')"
      class="fixed top-6 right-6 z-50 bg-gray-200 dark:bg-gray-700 text-gray-900 dark:text-white px-4 py-2 rounded shadow hover:ring ring-blue-300 dark:ring-blue-600 text-sm transition duration-300 ease-in-out"
      id="darkToggle"
    >
      🌞 Light / 🌙 Dark
    </button>

    <header class="bg-white shadow sticky top-0 z-40">
      <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
        <h1 class="text-2xl font-bold text-blue-700">📅 Todo App</h1>
        <%= link_to "New Task", new_task_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded shadow text-sm font-semibold" %>
      </div>
    </header>

    <%= themed_form_container { yield } %>

    <% flash.each do |type, message| %>
      <% colors = {
        notice: "bg-green-100 border border-green-400 text-green-700",
        alert:  "bg-red-100 border border-red-400 text-red-700"
      } %>

      <div class="max-w-xl mx-auto mt-6 p-4 rounded shadow text-sm <%= colors[type.to_sym] || 'bg-gray-100 text-gray-700' %>">
        <%= message %>
      </div>
    <% end %>

    <footer class="text-center text-sm text-gray-400 py-6">
      &copy; <%= Date.current.year %> Todo App by <strong>Ebrahim Solomon</strong>
    </footer>
  </body>
</html>
