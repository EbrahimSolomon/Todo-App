<%= form_with(model: task, local: true, html: { class: "space-y-6" }) do |form| %>
  <% if task.errors.any? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative">
      <h2 class="font-bold mb-2">
        <%= pluralize(task.errors.count, "error") %> prohibited this task from being saved:
      </h2>
      <ul class="list-disc list-inside text-sm">
        <% task.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= form.text_field :title, class: "mt-1 block w-full px-4 py-2 border rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-800 dark:text-white dark:border-gray-600" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= form.text_area :description, rows: 3, class: "mt-1 block w-full px-4 py-2 border rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-800 dark:text-white dark:border-gray-600" %>
  </div>

  <div>
    <%= form.label :due_date, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= form.date_field :due_date, class: "mt-1 block w-full px-4 py-2 border rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-800 dark:text-white dark:border-gray-600" %>
  </div>

  <div class="flex items-center">
    <%= form.check_box :completed, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 dark:bg-gray-800 dark:border-gray-600" %>
    <%= form.label :completed, class: "ml-2 text-sm text-gray-700 dark:text-gray-300" %>
  </div>

  <div>
    <%= form.submit "Save Task", class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded shadow transition dark:bg-blue-500 dark:hover:bg-blue-600" %>
  </div>
<% end %>
