<% content_for :title, "Edit Task" %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <h1 class="text-3xl font-bold text-gray-800 dark:text-white mb-6">✏️ Edit Task</h1>

  <%= render "form", task: @task %>

  <div class="mt-6 space-x-4">
    <%= link_to "👁 Show Task", @task, class: "text-blue-600 dark:text-blue-400 hover:underline" %>
    <%= link_to "← Back to Tasks", tasks_path, class: "text-blue-600 dark:text-blue-400 hover:underline" %>
  </div>
</div>
